# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zamerp
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=8h

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ZRA Smart Invoice (VSDC)
# Enable only after VSDC is deployed and initialized in your environment.
ZRA_VSDC_ENABLED=false
ZRA_VSDC_STRICT_MODE=false
ZRA_VSDC_USE_FALLBACK_VALUES=true
ZRA_VSDC_BASE_URL=http://localhost:8080
ZRA_VSDC_SALES_ENDPOINT=/trnsSales/saveSales
ZRA_VSDC_TPIN=
ZRA_VSDC_BHF_ID=000
ZRA_VSDC_CMC_KEY=
ZRA_VSDC_USE_REMOTE_CODES=true
ZRA_VSDC_CODE_ENDPOINT=/code/selectCodes
ZRA_VSDC_CODE_LAST_REQ_DT=20100101000000
ZRA_VSDC_CODE_CACHE_TTL_MINUTES=60

# Optional code defaults used in sales payload mapping
ZRA_VSDC_SALES_TYPE_CODE=N
ZRA_VSDC_RECEIPT_TYPE_CODE=S
ZRA_VSDC_PAYMENT_TYPE_CODE=01
ZRA_VSDC_TRANSACTION_PROGRESS_CODE=02
ZRA_VSDC_PACKAGE_UNIT_CODE=NT
ZRA_VSDC_QUANTITY_UNIT_CODE=U
ZRA_VSDC_TAX_TYPE_CODE=A
ZRA_VSDC_TAX_RATE_B=16
